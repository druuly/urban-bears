rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['firstName', 'lastName', 'schoolName'])
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.schoolName is string;
    }

    match /authors/{uid} {
      allow read: if true;
      allow write: if false;  // manage authors via console only
    }

    match /articles/{articleId} {
      allow read: if true;

      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/authors/$(request.auth.uid))
        && request.resource.data.authorUid == request.auth.uid;

      // Authors can fully edit their own articles.
      // Signed-in users can ONLY increment counter fields (likes/reposts/views).
      allow update: if request.auth != null && (
        resource.data.authorUid == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likeCount', 'repostCount', 'viewCount'])
      );

      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;

      match /likes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /reposts/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
